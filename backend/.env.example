PORT=4001
MONGODB_DB_NAME=sigemo_db
MONGODB_USERS_COLLECTION=usuarios
MONGODB_ROLES_COLLECTION=roles
MONGODB_PERMISSIONS_COLLECTION=permisos
MONGODB_USER_ROLES_COLLECTION=usuarios_roles
MONGODB_ROLE_PERMISSIONS_COLLECTION=roles_permisos
MONGODB_USER_PERMISSIONS_COLLECTION=usuarios_permisos
DATABASE_URL=mongodb://root:<PASSWORD>@nexus.liderman.net.pe:27017/sigemo_db?authSource=admin
CORS_ORIGINS=http://localhost:4002,http://127.0.0.1:4002

# ESTADOS-GADSO / Playwright
# Credenciales sensibles: definirlas en backend/ESTADOS-GADSO/.env o como variables del entorno de despliegue.
ESTADOS_GADSO_DIR=./ESTADOS-GADSO
ESTADOS_GADSO_PYTHON=
ESTADOS_GADSO_MAX_UPLOAD_MB=50
ESTADOS_GADSO_MAX_RETAINED_UPLOADS=0
ESTADOS_GADSO_UPLOAD_TTL_MINUTES=60
ESTADOS_GADSO_MAX_RETAINED_JOBS=10
ESTADOS_GADSO_MAX_CONCURRENT_JOBS=1
ESTADOS_GADSO_JOB_TIMEOUT_MINUTES=120
